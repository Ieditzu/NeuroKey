  tutorialMessage: 'Tutorial: read the code line by line, check which branch runs,
    then choose the value printed by cout.'
  alignToHoleDuration: 0.18
  descendIntoHoleDuration: 0.42
  riseFromHoleDuration: 0.3
  holeMouthHeight: 0.16
